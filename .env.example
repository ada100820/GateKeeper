# ─────────────────────────────────────────────────────────────────────────────
# GateKeeper — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub ───────────────────────────────────────────────────────────────────
# Automatically provided by GitHub Actions as secrets.GITHUB_TOKEN
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Set by the workflow from github.event.pull_request.number
PR_NUMBER=1

# Set by the workflow from github.repository (e.g. "org/repo")
REPO_FULL_NAME=your-org/your-repo

# Set by the workflow from github.event.pull_request.base.sha
BASE_SHA=abc1234

# Set by the workflow from github.event.pull_request.head.sha
HEAD_SHA=def5678

# ── Black Duck ────────────────────────────────────────────────────────────────
# Your Black Duck Hub URL (no trailing slash)
BD_API_URL=https://your-blackduck-instance.example.com

# Black Duck API token (Settings → Access Tokens → Generate)
BD_API_TOKEN=your-blackduck-api-token

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── AWS ───────────────────────────────────────────────────────────────────────
# AWS credentials with Pricing API read access + CloudWatch PutMetricData
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1

# ── Infracost ─────────────────────────────────────────────────────────────────
# Infracost API key (https://dashboard.infracost.io → API Keys)
INFRACOST_API_KEY=ico-xxxxxxxxxxxxxxxxxxxx
